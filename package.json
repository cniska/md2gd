{
  "name": "md2gd",
  "version": "0.1.0",
  "description": "Convert Markdown files into professionally styled Google Docs from the command line",
  "license": "MIT",
  "author": "Christoffer Niska",
  "keywords": [
    "markdown",
    "google-docs",
    "cli",
    "converter",
    "gfm",
    "bun"
  ],
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cniska/md2gd.git"
  },
  "bugs": {
    "url": "https://github.com/cniska/md2gd/issues"
  },
  "homepage": "https://github.com/cniska/md2gd#readme",
  "bin": {
    "md2gd": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "format": "bunx biome check --write .",
    "lint": "bunx biome check --error-on-warnings .",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "audit": "bun audit",
    "verify": "bun run lint && bun run typecheck && bun test && bun run audit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/bun": "^1.3.14",
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "mdast-util-to-string": "^4.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  }
}
